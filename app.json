{
  "expo": {
    "name": "Nutrisight",
    "slug": "Nutrisight",
    "scheme": "nutrisight",
    "version": "1.0.1",
    "orientation": "portrait",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/869a046d-5431-43e0-829c-842f00cf7407"
    },
    "icon": "./assets/images/nutrisight-notification.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/images/nutrisight.png",
      "resizeMode": "contain",
      "backgroundColor": "#37B37E"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.innovilage.nutrisight",
      "infoPlist": {
        "NSCameraUsageDescription": "Aplikasi ini memerlukan akses kamera untuk mengambil foto.",
        "NSMicrophoneUsageDescription": "Aplikasi ini memerlukan akses mikrofon untuk merekam video.",
        "NSPhotoLibraryUsageDescription": "Aplikasi ini memerlukan akses galeri untuk memilih foto.",
        "NSPhotoLibraryAddUsageDescription": "Aplikasi ini memerlukan akses untuk menyimpan foto ke galeri.",
        "NSUserTrackingUsageDescription": "Data ini digunakan untuk memberikan pengalaman yang lebih baik."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/nutrisight-notification.png",
        "backgroundColor": "#37B37E"
      },
      "package": "com.innovilage.nutrisight",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.NOTIFICATIONS",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.VIBRATE",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.SCHEDULE_EXACT_ALARM",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.INTERNET",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/images/nutrisight-notification.png"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Izinkan $(PRODUCT_NAME) mengakses kamera Anda",
          "microphonePermission": "Izinkan $(PRODUCT_NAME) mengakses mikrofon Anda",
          "recordAudioAndroid": true
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Aplikasi memerlukan akses ke foto Anda.",
          "cameraPermission": "Aplikasi memerlukan akses ke kamera Anda."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/nutrisight-notification.png",
          "color": "#dcfce7",
          "sounds": []
        }
      ],
      "expo-router"
    ],
    "extra": {
      "eas": {
        "projectId": "869a046d-5431-43e0-829c-842f00cf7407"
      }
    }
  }
}
